<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>RHODES // Archive</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>

  <!-- 顶部导航栏 -->
  <header class="topbar">
    <div class="topbar-logo">RHODES // ARCHIVE</div>
    <nav class="topbar-nav">
      <a href="#" class="nav-link active" data-index="0">HOME</a>
      <a href="#" class="nav-link" data-index="1">ACHIEVE</a>
      <a href="#" class="nav-link" data-index="2">CATEGORY</a>
    </nav>
  </header>

  <!-- 全屏横向滚动父容器 -->
  <div class="main-container">

    <!-- 01 Home -->
    <section class="section home-section">
      <div class="home-content">
        <h1>Welcome to RHODES</h1>
        <p>Future short clip background will appear here.</p>
      </div>
    </section>

    <!-- 02 Post Section -->
    <section class="section post-section">
      <div class="post-carousel">

        <!-- 左右切换按钮 -->
        <button class="carousel-btn prev">&lt;</button>

        <!-- 卡片轨道 -->
        <div class="carousel-track">
          <article class="post-card">
            <div class="post-image"></div>
            <h3 class="post-title">Article 1</h3>
            <p class="post-excerpt">This is the summary of article 1.</p>
          </article>
          <article class="post-card">
            <div class="post-image"></div>
            <h3 class="post-title">Article 2</h3>
            <p class="post-excerpt">This is the summary of article 2.</p>
          </article>
          <article class="post-card">
            <div class="post-image"></div>
            <h3 class="post-title">Article 3</h3>
            <p class="post-excerpt">This is the summary of article 3.</p>
          </article>
          <!-- 可以继续添加更多卡片 -->
        </div>

        <button class="carousel-btn next">&gt;</button>

        <!-- 分页 -->
        <div class="carousel-pagination">
          <span class="page active">1</span>
          <span class="page">2</span>
          <span class="page">3</span>
          <span class="page">...</span>
          <span class="page">Last</span>
        </div>
      </div>
    </section>

    <!-- 03 Category Section -->
    <section class="section category-section">
      <div class="category-left">
        <!-- 粒子动态图标占位 -->
      </div>
      <div class="category-right">
        <ul>
          <li>Category 1</li>
          <li>Category 2</li>
          <li>Category 3</li>
          <li>Category 4</li>
          <li>Category 5</li>
        </ul>
      </div>
    </section>

  </div> <!-- /main-container -->

  <script src="script.js"></script>
</body>
</html>